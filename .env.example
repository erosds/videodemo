# ── DemoPlatform environment variables ──────────────────────────────────────
# Copy to .env and edit as needed. docker-compose.yml reads these automatically.

# Backend → Qdrant URL (Docker internal; use http://localhost:6333 for local dev)
QDRANT_URL=http://qdrant:6333

# Backend → Ollama URL (Docker internal; use http://localhost:11434 for local dev)
OLLAMA_URL=http://ollama:11434

# Backend → Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:3000
